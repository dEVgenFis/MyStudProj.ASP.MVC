{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/my_stud_proj-log-.json",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 1,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      },
      {
        "Name": "Console",
        "Args": {
          // "Timestamp" - параметр, определяющий время возникновения лога
          // "HH:mm:ss" - формат времени
          // "Level" - параметр, описывающий уровень лога
          // "u3" - формат лога (3 символа в верхнем регистре)
          // "SourceContext" - параметр, определяющий место (пространство имен) возникновения лога
          // "Message" - параметр, определяющий текст сообщения лога
          // "l" - модификатор, отсеивающий кавычки вокруг текста сообщения лога
          // "NewLine" - параметр переноса "каретки"
          // "Exception" - параметр вывода данных об ошибке при ее возникновении
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:l}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "MySQLConnection": "Your_ConnectionString"
  }
}
